generator client {
  provider = "prisma-client"
  output = "./client"
  previewFeatures = ["relationJoins"]
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model PasswordReset {
  id        String   @id
  email     String
  otp       String
  createdAt DateTime @default(now())
  expiresAt DateTime
  isUsed    Boolean  @default(false)

  @@index([email])
}

model TokenBlacklist {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model User {
  id        String       @id
  email     String       @unique
  password  String?
  fullName  String?
  avatar    String?
  createdAt DateTime     @default(now())
  updatedAt DateTime
  role      String       @default("USER")
  googleId  String?      @unique
  typeAuth  authProvider @default(EMAIL)
  metadata  Json?
  phone     String?      @unique
  status    UserStatus   @default(ACTIVE)
}

enum authProvider {
  EMAIL
  GOOGLE
}

// ACTIVE is the DB-level default so existing rows stay accessible after migration.
// New registrations always receive PENDING explicitly in application code.
enum UserStatus {
  PENDING
  ACTIVE
  BLOCKED
}
