generator client {
  provider = "prisma-client"
  output = "./client"
  previewFeatures = ["relationJoins"]
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model PasswordReset {
  id        String   @id
  email     String
  otp       String
  createdAt DateTime @default(now())
  expiresAt DateTime
  isUsed    Boolean  @default(false)

  @@index([email])
}

model TokenBlacklist {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model User {
  id                        String                       @id
  email                     String                       @unique
  password                  String?
  fullName                  String?
  avatar                    String?
  createdAt                 DateTime                     @default(now())
  updatedAt                 DateTime
  role                      String                       @default("USER")
  googleId                  String?                      @unique
  typeAuth                  authProvider                 @default(EMAIL)
  metadata                  Json?
  phone                     String?                      @unique
  status                    UserStatus                   @default(ACTIVE)
  // 2FA fields
  twoFactorEnabled          Boolean                      @default(false)
  totpSecret                String?
  twoFactorRecoveryCodes    TwoFactorRecoveryCode[]
  timelineEvents            TimelineEvent[]

  @@map("users")
}

enum authProvider {
  EMAIL
  GOOGLE
}

// ACTIVE is the DB-level default so existing rows stay accessible after migration.
// New registrations always receive PENDING explicitly in application code.
enum UserStatus {
  PENDING
  ACTIVE
  BLOCKED
}

model TwoFactorRecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  code      String    // hashed recovery code
  isUsed    Boolean   @default(false)
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("two_factor_recovery_codes")
}

model TimelineEvent {
  id        Int       @id @default(autoincrement())
  userUuid  String    @map("user_uuid")
  eventType EventType @map("event_type")
  title     String
  metadata  Json?
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userUuid], references: [id], onDelete: Cascade)

  @@index([userUuid])
  @@map("timeline_events")
}

enum EventType {
  JOIN_BCN
  COURSE_COMPLETE
  QUIZ_COMPLETE
  PROJECT_COMPLETE
  SEMESTER_COMPLETE
}
